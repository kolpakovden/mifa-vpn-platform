{
  "dns": {
    "servers": [
      "https+local://8.8.8.8/dns-query",
      "https+local://1.1.1.1/dns-query",
      "localhost"
    ]
  },
  "log": {
    "loglevel": "info",
    "access": "/var/log/xray/access.log",
    "dnsLog": false
  },
  "inbounds": [
    {
      "tag": "VLESS-Reality-443",
      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "__UUID__",
            "flow": "xtls-rprx-vision",
            "email": "admin@myserver.com"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "target": "www.microsoft.com:443",
          "xver": 0,
          "spiderX": "/",
          "serverNames": [
            "www.microsoft.com",
            "www.github.com",
            "www.cloudflare.com",
            "www.apple.com",
            "www.google.com"
          ],
          "privateKey": "__PRIVATE_KEY__",
          "shortIds": ["__SHORT_ID__"]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"]
      }
    },
