{
  "dns": {
    "servers": [
      "https+local://1.1.1.1/dns-query",
      "https+local://dns10.quad9.net/dns-query",
      "8.8.8.8"
    ],
    "queryStrategy": "UseIPv4"
  },
  "log": {
    "loglevel": "info",
    "access": "/var/log/xray/access.log",
    "dnsLog": false
  },
  "inbounds": [
    {
      "tag": "VLESS-Reality-8443",
      "listen": "0.0.0.0",
      "port": 8443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "__UUID__",
            "flow": "xtls-rprx-vision",
            "email": "admin@myserver.com"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "target": "__TARGET__",
          "xver": 0,
          "spiderX": "/",
          "serverNames": [
            "www.academia.edu",
            "www.researchgate.net",
            "www.jstor.org",
            "www.sciencedirect.com"
          ],
          "privateKey": "__PRIVATE_KEY__",
          "shortIds": [
            "__SHORT_ID__"
          ]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    },
    {
      "tag": "VLESS-Reality-50273",
      "listen": "0.0.0.0",
      "port": 50273,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "__UUID__",
            "flow": "xtls-rprx-vision",
            "email": "admin@myserver.com"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "target": "__TARGET__",
          "xver": 0,
          "spiderX": "/",
          "serverNames": [
            "www.academia.edu",
            "www.researchgate.net",
            "www.jstor.org",
            "www.sciencedirect.com"
          ],
          "privateKey": "__PRIVATE_KEY__",
          "shortIds": [
            "__SHORT_ID__"
          ]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct",
      "settings": {
        "domainStrategy": "ForceIPv4"
      }
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    }
  ],
  "routing": {
    "rules": [
      {
        "type": "field",
        "domain": [
          "geosite:win-spy"
        ],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "ip": [
          "geoip:private"
        ],
        "outboundTag": "block"
      }
    ]
  }
}
